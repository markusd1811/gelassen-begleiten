---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, ""); // Remove trailing slash if exists
---

<!-- Sticky CTA Banner for Conversion -->
<div class="top-banner">
    <span>Erster Schritt: Sichere dir dein kostenfreies Erstgespräch.</span>
    <a href="#kontakt">Termin finden →</a>
</div>

<nav class="navbar">
    <div class="logo">
        <a href="/">
            <img src="/images/logo_gb.png" alt="Logo Gelassen Begleiten" />
            <div class="logo-divider"></div>
            <span class="logo-text">Laura Drühe</span>
        </a>
    </div>
    <button class="mobile-menu-btn" aria-label="Menü öffnen">
        <span></span>
        <span></span>
        <span></span>
    </button>
    <ul class="nav-links">
        <li>
            <a
                href="/lilaliebe"
                class={currentPath === "/lilaliebe" ? "active" : ""}
                >LilaLiebe®</a>
        </li>
        <li>
            <a
                href="/familiencoaching-online"
                class={currentPath === "/familiencoaching-online"
                    ? "active"
                    : ""}>Coaching</a>
        </li>
        <li>
            <a
                href="/ueber-mich"
                class={currentPath === "/ueber-mich" ? "active" : ""}
                >Über mich</a>
        </li>
        <li>
            <a
                href="/blog"
                class={currentPath.startsWith("/blog") ? "active" : ""}
                >Impulse</a>
        </li>
        <li>
            <a href="/faq" class={currentPath === "/faq" ? "active" : ""}
                >FAQ</a>
        </li>
        <li><a href="/#kontakt" class="btn-primary-small">Termin buchen</a></li>
    </ul>
</nav>
