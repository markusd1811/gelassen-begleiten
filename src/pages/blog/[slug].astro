---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Provide fallback values if SEO fields are missing
const pageTitle = entry.data.seo_title || `${entry.data.title} | Laura Drühe`;
const pageDescription =
  entry.data.seo_description ||
  entry.data.answer_capsule ||
  `LilaLiebe® Beratung & Familiencoaching: ${entry.data.title}`;

// Schema Markup (Article/FAQ)
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: pageDescription,
  author: {
    "@type": "Person",
    name: "Laura Drühe",
    url: "https://gelassen-begleiten.de/ueber-mich/",
  },
};

// --- FAQ Auto-Extraction from Markdown Body ---
const rawBody = entry.body || "";
const lines = rawBody.split("\n");
const faqQuestions = [];
let currentQuestion = null;
let currentAnswer = [];
let inFaqSection = false;

for (const line of lines) {
  const trimmed = line.trim();

  if (trimmed.startsWith("## ") && trimmed.toLowerCase().includes("fragen")) {
    inFaqSection = true;
    continue;
  }

  if (!inFaqSection) continue;

  // Stop FAQ parsing if we hit a horizontal rule or a new primary/secondary heading
  if (
    trimmed === "---" ||
    (trimmed.startsWith("## ") && !trimmed.toLowerCase().includes("fragen"))
  ) {
    if (currentQuestion) {
      faqQuestions.push({
        question: currentQuestion,
        answer: currentAnswer.join("\n").trim(),
      });
      currentQuestion = null;
      currentAnswer = [];
    }
    inFaqSection = false;
    continue;
  }

  // Detect bold question
  if (
    trimmed.startsWith("**") &&
    trimmed.endsWith("**") &&
    trimmed.includes("?")
  ) {
    if (currentQuestion) {
      faqQuestions.push({
        question: currentQuestion,
        answer: currentAnswer.join("\n").trim(),
      });
    }
    currentQuestion = trimmed.replace(/^\*\*|\*\*$/g, "");
    currentAnswer = [];
  } else if (currentQuestion && trimmed !== "") {
    // If it's a list or paragraph, add it to the answer
    currentAnswer.push(trimmed);
  }
}
// Push the last question if the file ended while parsing FAQs
if (currentQuestion) {
  faqQuestions.push({
    question: currentQuestion,
    answer: currentAnswer.join("\n").trim(),
  });
}

let faqSchema = null;
if (faqQuestions.length > 0) {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqQuestions.map((q) => ({
      "@type": "Question",
      name: q.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: q.answer,
      },
    })),
  };
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={entry.data.image}
>
  <slot name="head" slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)}
    ></script>
    {
      faqSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(faqSchema)}
        />
      )
    }
  </slot>

  <Navbar />

  <main class="blog-post">
    <article class="container">
      <div class="blog-header text-center">
        <h1>{entry.data.title}</h1>
      </div>

      {
        entry.data.answer_capsule && (
          <div class="answer-capsule">
            <p>
              <strong>Die kurze Antwort:</strong>
            </p>
            <p>{entry.data.answer_capsule}</p>
          </div>
        )
      }

      {
        entry.data.image && (
          <img
            src={entry.data.image}
            alt={entry.data.title}
            class="blog-hero-image"
          />
        )
      }

      <div class="blog-content">
        <Content />
      </div>

      <div class="cta-box text-center mt-4">
        <h3>Lass uns das gemeinsam ansehen</h3>
        <p>
          Du hast gerade eine akute Situation? Schreib mir oder buche ein
          Erstgespräch.
        </p>
        <a href="/#kontakt" class="btn-primary" style="margin-top: 1rem;"
          >Erstgespräch vereinbaren</a
        >
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .blog-post {
    padding: 8rem 2rem 4rem; /* Spacing below fixed navbar */
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .blog-header {
    margin-bottom: 2rem;
  }
  .blog-header h1 {
    color: var(--clr-primary-dark);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    line-height: 1.2;
  }
  .answer-capsule {
    background-color: var(--clr-primary-light);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    margin-bottom: 2.5rem;
    font-weight: 500;
  }
  .blog-hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: 2rem;
  }
  .blog-content {
    margin-bottom: 3rem;
  }
  .blog-content :global(h2) {
    color: var(--clr-primary-dark);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }
  .blog-content :global(h3) {
    color: var(--clr-text-main);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }
  .blog-content :global(p) {
    margin-bottom: 1.2rem;
  }
  .cta-box {
    background-color: var(--clr-bg-warm);
    padding: 2.5rem 2rem;
    border-radius: var(--radius-lg);
    border-top: 4px solid var(--clr-primary);
  }
</style>
