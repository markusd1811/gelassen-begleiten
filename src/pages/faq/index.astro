---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const faqEntries = await getCollection('faq');

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqEntries.map(entry => ({
    "@type": "Question",
    "name": entry.data.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": entry.data.answer
    }
  }))
};
---

<Layout title="Häufige Fragen (FAQ) | Laura Drühe Familiencoaching" description="Antworten auf die häufigsten Fragen rund um Familiencoaching, Ablauf und die Gewaltfreie Kommunikation.">
    <slot name="head" slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    </slot>

    <Navbar />

    <header class="section-warm text-center" style="padding-top: 8rem; padding-bottom: 4rem;">
        <div class="container">
            <h1>Häufig gestellte Fragen</h1>
            <p class="subtitle" style="max-width: 600px; margin: 1rem auto;">Hier findest du Antworten auf die Fragen, die mir am häufigsten gestellt werden.</p>
        </div>
    </header>

    <section class="section-light" style="padding-top: 2rem;">
        <div class="container">
            <div class="faq-accordion mt-4">
                {faqEntries.map((faq) => (
                    <div class="faq-item">
                        <div class="faq-header">
                            <h4>{faq.data.question} <span style="font-size: 0.8rem; font-weight: 400; padding: 0.2rem 0.6rem; background: var(--clr-bg-warm); color: var(--clr-text-secondary); border-radius: 1000px; margin-left: 1rem; white-space: nowrap;">{faq.data.category}</span></h4>
                            <span class="faq-icon">+</span>
                        </div>
                        <div class="faq-content">
                            <p>{faq.data.answer}</p>
                        </div>
                    </div>
                ))}
            </div>
            
            <div class="text-center mt-4 pt-4">
                <p>Deine Frage war nicht dabei?</p>
                <a href="/#kontakt" class="btn-primary mt-2">Schreib mir gerne</a>
            </div>
        </div>
    </section>

    <Footer />
</Layout>
