---
import { getCollection } from "astro:content";
import { marked } from "marked";
import homeData from "../data/home.json";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const blogEntries = await getCollection("blog");
const sortedEntries = blogEntries
    .sort((a, b) => {
        return (
            new Date(b.data.date || 0).valueOf() -
            new Date(a.data.date || 0).valueOf()
        );
    })
    .slice(0, 3); // latest 3

const faqEntries = await getCollection("faq");
const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqEntries.map((entry) => ({
        "@type": "Question",
        name: entry.data.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: entry.data.answer,
        },
    })),
};

const schema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "LocalBusiness",
            name: "Laura Drühe - Gelassen begleiten",
            image: "https://gelassen-begleiten.de/images/logo_gb.png",
            email: "hallo@gelassen-begleiten.de",
            address: {
                "@type": "PostalAddress",
                streetAddress: "Sachsenweg 53a",
                addressLocality: "Hamburg",
                postalCode: "22455",
                addressCountry: "DE",
            },
            url: "https://gelassen-begleiten.de",
        },
        {
            "@type": "Person",
            name: "Laura Drühe",
            jobTitle: "Familiencoach nach GFK",
            url: "https://gelassen-begleiten.de",
            image: "https://gelassen-begleiten.de/images/laura-druehe_quadrat.jpg",
        },
    ],
};
---

<Layout
    title="Familiencoaching GFK online | Gelassen begleiten"
    description="Familiencoaching nach GFK und LilaLiebe® – online via Zoom, alltagstauglich und ohne Wertung. Zertifizierte LilaLiebe®-Beraterin Laura Drühe. Erstgespräch kostenlos."
>
    <slot name="head" slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)}
        ></script>
        <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}
        ></script>
    </slot>

    <Navbar />

    <!-- 1. HERO -->
    <header id="home" class="hero">
        <div class="hero-content">
            <span class="badge">{homeData.hero.badge}</span>
            <h1 class="fade-in-up">
                {homeData.hero.title_main}
                <span class="highlight">{homeData.hero.title_highlight}</span>
            </h1>
            <p class="subtitle fade-in-up delay-1">{homeData.hero.subtitle}</p>
            <div class="cta-buttons fade-in-up delay-2">
                <a href="#erstgespraech" class="btn-primary"
                    >Erstgespräch vereinbaren</a
                >
                <a href="#problem" class="btn-secondary">Ist das für uns?</a>
            </div>
            <!-- Trust Elements under CTA -->
            <div class="trust-marks fade-in-up delay-2">
                <span
                    >✓ Gewaltfreie Kommunikation nach Marshall B. Rosenberg</span
                >
                <span>✓ LilaLiebe®-Methode (BDVT-zertifiziert)</span>
                <span>✓ Online via Zoom – deutschlandweit</span>
                <span>✓ Alltagstaugliche Werkzeuge</span>
            </div>
        </div>
        <div class="header-image-wrapper fade-in">
            <div class="soft-shape"></div>
            <img
                src={homeData.hero.image}
                alt="Hero Bild"
                class="header-image"
            />
        </div>
    </header>

    <!-- 2. PROBLEM-AWARENESS -->
    <section id="problem" class="section-light">
        <div class="container">
            <div class="section-header text-center">
                <h2>{homeData.problem.title}</h2>
                <div class="separator"></div>
                <p>{homeData.problem.text}</p>
            </div>
            <div class="pain-points-grid">
                <div class="pain-card">
                    <span class="pain-icon">💬</span>
                    <h3>Kleinigkeiten eskalieren</h3>
                    <p>
                        Du weißt nicht, was dein Kind gerade wirklich antreibt –
                        und reagierst lauter, als du eigentlich wolltest.
                    </p>
                </div>
                <div class="pain-card">
                    <span class="pain-icon">⚖️</span>
                    <h3>Dieselben Situationen</h3>
                    <p>
                        Anziehen, Essen, Schlafengehen – täglich dieselben
                        Machtkämpfe, die Energie kosten und die Verbindung
                        belasten.
                    </p>
                </div>
                <div class="pain-card">
                    <span class="pain-icon">🧠</span>
                    <h3>Ungewollte Reaktionen</h3>
                    <p>
                        Und danach das schlechte Gewissen. Das Gefühl: Ich
                        müsste das doch besser hinbekommen. Du bist damit nicht
                        allein.
                    </p>
                </div>
            </div>
            <div class="text-center mt-4">
                <p
                    class="large-text font-bold"
                    style="color: var(--clr-primary-dark);"
                >
                    Du bist damit nicht allein. Und es liegt nicht daran, dass
                    du versagst.
                </p>
            </div>
        </div>
    </section>

    <!-- 3. SOLUTION / METHODE -->
    <section id="methode" class="section-warm">
        <div class="container">
            <div class="grid-2 align-center">
                <div class="text-block">
                    <h2>{homeData.methode.title}</h2>
                    <div class="separator-left"></div>
                    <div set:html={marked.parse(homeData.methode.text)}></div>

                    <ul class="benefits-list">
                        <li>
                            <strong>Orientierung in Autonomiephasen:</strong> Verstehe,
                            was entwicklungspsychologisch in deinem Kind vorgeht.
                        </li>
                        <li>
                            <strong>Eigene Trigger erkennen:</strong> Erkenne, was
                            deine eigenen Reaktionen auslöst – und lerne, aus der
                            Ruhe heraus zu antworten.
                        </li>
                        <li>
                            <strong>Sofort anwendbare Werkzeuge:</strong> Keine unpraktischen
                            Theorien, sondern konkret umsetzbare Sätze für deinen
                            Alltag.
                        </li>
                    </ul>
                    <a
                        href="/lilaliebe"
                        class="btn-primary"
                        style="margin-top: 2rem;">Mehr zur LilaLiebe® Methode</a
                    >
                </div>
                <div class="image-box">
                    <img
                        src={homeData.methode.image}
                        alt="LilaLiebe Methode Symbolbild"
                        class="rounded-image shadow-md"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- 4. SOCIAL PROOF / TESTIMONIALS -->
    <section class="section-light">
        <div class="container text-center">
            <h2>Was andere Eltern sagen</h2>
            <div class="separator"></div>

            <div class="testimonial-slider">
                <div class="testimonial-card">
                    <div class="stars">⭐⭐⭐⭐⭐</div>
                    <p>
                        „Laura hat mir buchstäblich die Augen geöffnet. Wir
                        dachten, unser Sohn (4) sei einfach extrem kompliziert.
                        Schon nach der ersten Session habe ich verstanden, was
                        hinter seinen Wutausbrüchen steckt. Es ist so viel
                        ruhiger bei uns geworden!“
                    </p>
                    <span class="author">- Sarah, Mama von zwei Kindern</span>
                </div>
                <div class="testimonial-card">
                    <div class="stars">⭐⭐⭐⭐⭐</div>
                    <p>
                        „Die Audio-Quick-Beratung war meine Rettung in einer
                        völlig verfahrenen Schlafsituation. Lauras
                        Sprachnachricht war so empathisch und voller klarer,
                        direkt umsetzbarer Tipps ohne erhobenen Zeigefinger.“
                    </p>
                    <span class="author">- Michael, Papa von Lea (3)</span>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. AUTHORITY / ABOUT -->
    <section id="about" class="section-warm">
        <div class="container grid-2 align-center">
            <div class="image-box text-center">
                <img
                    src={homeData.about.image}
                    alt="Laura Portrait"
                    class="about-image"
                    style="width:80%; aspect-ratio:1/1; object-fit:cover; border-radius:50%; box-shadow:var(--shadow-soft);"
                />
            </div>
            <div class="text-block">
                <h2>{homeData.about.title}</h2>
                <div class="separator-left"></div>
                <div set:html={marked.parse(homeData.about.text)}></div>
                <a
                    href="/ueber-mich"
                    class="btn-outline"
                    style="margin-top: 1.5rem;">Mehr über mich erfahren →</a
                >
            </div>
        </div>
    </section>

    <!-- 6. ANGEBOTE -->
    <section id="angebote" class="section-light">
        <div class="container text-center">
            <h2>Wähle eure Begleitung</h2>
            <div class="separator"></div>
            <p class="section-subtitle">
                Investiere in die nachhaltige Beziehung zu deinem Kind.
            </p>

            <div class="cards-grid fade-up-elements">
                <div class="service-card">
                    <h3>Audio-Quick-Beratung</h3>
                    <div class="price">29 €</div>
                    <p>
                        Du hast eine akute Situation und brauchst schnell einen
                        konkreten Impuls.
                    </p>
                    <ul class="service-features">
                        <li>Schick mir eine Sprachnachricht</li>
                        <li>Antwort innerhalb von 48 Stunden</li>
                        <li>Gezielte, auf euch zugeschnittene Tipps</li>
                    </ul>
                    <a href="#erstgespraech" class="btn-outline">Jetzt buchen</a
                    >
                    <a
                        href="/audio-quick-beratung"
                        style="display: block; margin-top: 1rem; font-size: 0.9rem; color: var(--clr-text-secondary); text-decoration: underline;"
                        >Mehr Details zum Ablauf →</a
                    >
                </div>

                <div class="service-card popular">
                    <div class="badge-popular">Für Einzelpersonen</div>
                    <h3>1:1-Coaching</h3>
                    <div class="price">
                        200 € <span class="duration">/ 2 Termine</span>
                    </div>
                    <p>
                        Zwei Zoom-Termine à 60 Min. Selbsteinfühlung im ersten
                        Termin, Fremdeinfühlung im zweiten.
                    </p>
                    <ul class="service-features">
                        <li>Tiefenblick auf euer zentrales "Warum"</li>
                        <li>Direkt umsetzbare Sätze für den Alltag</li>
                        <li>Handwerkszeug für eure Beziehung</li>
                    </ul>
                    <a href="#erstgespraech" class="btn-primary w-100"
                        >Termin finden</a
                    >
                    <a
                        href="/einzelcoaching"
                        style="display: block; margin-top: 1rem; font-size: 0.9rem; color: var(--clr-text-secondary); text-decoration: underline;"
                        >Mehr Details zum Ablauf →</a
                    >
                </div>

                <div class="service-card">
                    <h3>Paarberatung</h3>
                    <div class="price">
                        300 € <span class="duration">/ 3 Termine</span>
                    </div>
                    <p>
                        Drei Zoom-Termine. Für Elternteams, die gemeinsam in
                        dieselbe Richtung wachsen wollen.
                    </p>
                    <ul class="service-features">
                        <li>Gemeinsamer Perspektivwechsel</li>
                        <li>Selbsteinfühlung für beide Personen</li>
                        <li>Werkzeuge für euch als Elternteam</li>
                    </ul>
                    <a href="#erstgespraech" class="btn-outline">Paket buchen</a
                    >
                    <a
                        href="/paarberatung"
                        style="display: block; margin-top: 1rem; font-size: 0.9rem; color: var(--clr-text-secondary); text-decoration: underline;"
                        >Mehr Details zum Ablauf →</a
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- 7. FAQ -->
    <section id="faq" class="section-warm">
        <div class="container">
            <h2 class="text-center">Häufig gestellte Fragen</h2>
            <div class="separator"></div>
            <div class="faq-accordion mt-4">
                {
                    faqEntries.map((faq) => (
                        <div class="faq-item">
                            <div class="faq-header">
                                <h4>{faq.data.question}</h4>
                                <span class="faq-icon">+</span>
                            </div>
                            <div class="faq-content">
                                <p>{faq.data.answer}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
            <div class="text-center mt-4 pt-4">
                <a href="/faq" class="btn-outline">Alle Fragen lesen</a>
            </div>
        </div>
    </section>

    <!-- 7.5 AKTUELLE IMPULSE / BLOG -->
    <section id="blog" class="section-light" style="background-color: #ffffff;">
        <div class="container">
            <h2 class="text-center">Aktuelle Impulse für dich</h2>
            <div class="separator"></div>
            <p
                class="section-subtitle text-center"
                style="margin-bottom: 3rem;"
            >
                Tieferes Wissen und Lösungsansätze rund um den Familienalltag.
            </p>

            <div class="cards-grid fade-up-elements">
                {
                    sortedEntries.map((post) => (
                        <a
                            href={`/blog/${post.slug}`}
                            class="service-card"
                            style="text-decoration: none; color: inherit; display: flex; flex-direction: column; transition: transform 0.3s ease;"
                        >
                            {post.data.image && (
                                <div style="margin: -2rem -2rem 1.5rem -2rem; border-radius: 20px 20px 0 0; overflow: hidden; height: 180px;">
                                    <img
                                        src={post.data.image}
                                        alt={post.data.title}
                                        style="width: 100%; height: 100%; object-fit: cover;"
                                    />
                                </div>
                            )}
                            <h3 style="font-size: 1.25rem;">
                                {post.data.title}
                            </h3>
                            <p style="font-size: 0.95rem; margin-top: 1rem; flex-grow: 1;">
                                {post.data.answer_capsule
                                    ? post.data.answer_capsule.substring(
                                          0,
                                          120
                                      ) + "..."
                                    : ""}
                            </p>
                            <span style="display: block; margin-top: 1.5rem; color: var(--clr-primary); font-weight: 600;">
                                Weiterlesen →
                            </span>
                        </a>
                    ))
                }
            </div>
            {
                sortedEntries.length === 0 && (
                    <p class="text-center" style="margin-top: 2rem;">
                        In Kürze findest du hier erste Beiträge.
                    </p>
                )
            }

            <div class="text-center mt-4 pt-4">
                <a href="/blog" class="btn-outline">Zu allen Beiträgen</a>
            </div>
        </div>
    </section>

    <!-- 8. FINAL CTA -->
    <section id="erstgespraech" class="section-light">
        <div class="container">
            <div class="contact-wrapper">
                <div class="contact-text">
                    <h2>Dein nächster Schritt</h2>
                    <p>
                        Lass uns gemeinsam schauen, ob die Chemie stimmt. Das
                        kostenfreie Erstgespräch dauert 15–20 Minuten – per Zoom
                        oder Telefon, ganz unkompliziert.
                    </p>

                    <div class="free-call-box">
                        <h3>Kennenlerngespräch</h3>
                        <p class="font-bold">Kostenlos</p>
                        <p>
                            Kein Druck, keine Verpflichtung. Nur ein ehrliches
                            Gespräch darüber, was gerade los ist – und ob und
                            wie ich dir helfen kann.
                        </p>
                        <a
                            href="mailto:hallo@gelassen-begleiten.de"
                            class="btn-primary"
                            style="margin-top: 1.5rem; display: inline-block;"
                            >Jetzt Termin buchen</a
                        >
                    </div>

                    <div class="contact-info mt-4">
                        <div class="info-item">
                            <span class="icon">✉️</span>
                            <a
                                href="mailto:hallo@gelassen-begleiten.de"
                                style="color: inherit; text-decoration: none;"
                                >hallo@gelassen-begleiten.de</a
                            >
                        </div>
                    </div>
                </div>
                <div
                    class="contact-form-container"
                    style="background: #fff; border-radius: 0 24px 24px 0;"
                >
                    <!-- Calendly inline widget begin -->
                    <div
                        class="calendly-inline-widget"
                        data-url="https://calendly.com/laura-druehe"
                        style="min-width:320px;height:700px;"
                    >
                    </div>
                    <script
                        type="text/javascript"
                        src="https://assets.calendly.com/assets/external/widget.js"
                        async
                    ></script>
                    <!-- Calendly inline widget end -->
                    <p
                        style="font-size: 0.75rem; color: #999; padding: 1rem; line-height: 1.3;"
                    >
                        Hinweis: Mit der Nutzung des Kalenders erklärst du dich
                        mit der Übermittlung deiner Daten an Calendly und deren
                        Verarbeitung gemäß unserer <a
                            href="/datenschutz.html"
                            style="color: inherit; text-decoration: underline;"
                            >Datenschutzerklärung</a
                        > einverstanden.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <Footer />
</Layout>
