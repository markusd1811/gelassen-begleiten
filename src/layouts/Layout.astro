---
interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = "Laura Drühe - Familiencoaching nach Gewaltfreier Kommunikation. Gelassen begleiten.",
	image = "/images/hero-family.webp",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="robots" content="noindex, nofollow" />

		<!-- Preload Critical Fonts -->
		<link
			rel="preload"
			href="/fonts/Nunito/static/Nunito-Regular.ttf"
			as="font"
			type="font/ttf"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Nunito/static/Nunito-SemiBold.ttf"
			as="font"
			type="font/ttf"
			crossorigin
		/>
		<link
			rel="preload"
			href="/fonts/Lora/static/Lora-Regular.ttf"
			as="font"
			type="font/ttf"
			crossorigin
		/>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta
			property="og:url"
			content={`https://gelassen-begleiten.de${Astro.url.pathname}`}
		/>
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta
			property="og:image"
			content={`https://gelassen-begleiten.de${image}`}
		/>

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta
			property="twitter:url"
			content={`https://gelassen-begleiten.de${Astro.url.pathname}`}
		/>
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta
			property="twitter:image"
			content={`https://gelassen-begleiten.de${image}`}
		/>

		<link
			rel="canonical"
			href={`https://gelassen-begleiten.de${Astro.url.pathname}`}
		/>
		<link
			rel="alternate"
			hreflang="de"
			href={`https://gelassen-begleiten.de${Astro.url.pathname}`}
		/>
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<title>{title}</title>
		<link rel="stylesheet" href="/styles.css" />
		<slot name="head" />
	</head>
	<body>
		<slot />
		<script is:inline defer src="/script.js"></script>
	</body>
</html>
