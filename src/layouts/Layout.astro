---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Laura Drühe - Familiencoaching nach Gewaltfreier Kommunikation. Gelassen begleiten." } = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="canonical" href={`https://gelassen-begleiten.de${Astro.url.pathname}`} />
		<link rel="alternate" hreflang="de" href={`https://gelassen-begleiten.de${Astro.url.pathname}`} />
		<title>{title}</title>
		<link rel="stylesheet" href="/styles.css" />
		<slot name="head" />
	</head>
	<body>
		<slot />
		<script is:inline src="/script.js"></script>
	</body>
</html>
